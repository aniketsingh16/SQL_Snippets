import re

def extract_filter_criteria(pattern):
    match = re.search(r'(\d{4})(?:_(\d{2}))?(?:_(\d{2}))?', pattern)
    
    if not match:
        return None, None, None
    
    year = match.group(1)
    month = match.group(2)  # optional
    day = match.group(3)    # optional
    
    return year, month, day

def file_matches(filename, year, month=None, day=None):
    match = re.search(r'(\d{4})_(\d{2})_(\d{2})', filename)
    
    if not match:
        return False
    
    file_year, file_month, file_day = match.groups()
    
    if day:  # Most specific
        return (
            file_year == year and
            file_month == month and
            file_day == day
        )
    
    if month:  # Month level
        return file_year == year and file_month == month
    
    # Year level
    return file_year == year
def filter_files(file_list, pattern):
    year, month, day = extract_filter_criteria(pattern)
    
    if not year:
        return []
    
    return [
        f for f in file_list
        if file_matches(f, year, month, day)
    ]
