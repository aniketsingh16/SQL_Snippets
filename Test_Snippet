There's a gcs bucket, in which there are two folders, compressed and decompressed. There are zip files in compressed folder. Now, write a cloud function in gen2 which unzips the zip file from compressed and move the file in the decompressed folder. Please ensure there should be no infinite loop, i.e. there should be a trigger so that the function only runs when there's a new zip file arrives in the compressed folder. Also make sure I don't want to download zip file in memory at all.

SELECT 
    Model,
    Brand,
    Tyre_Pressure, 
    Tyre_Pressure * 0.0145 AS Tyre_Pressure_PSI,
    CASE 
        WHEN Tyre_Pressure * 0.0145 BETWEEN 3 AND 10 
        THEN 'KPA (Needs Conversion)' 
        ELSE 'HPA (Correct Value)' 
    END AS Pressure_Type,
    -- If it's in KPA, convert to HPA by multiplying by 10
    CASE 
        WHEN Tyre_Pressure * 0.0145 BETWEEN 3 AND 10 
        THEN Tyre_Pressure * 10 
        ELSE Tyre_Pressure 
    END AS Converted_Tyre_Pressure
FROM  `vocal-operand-452018-n2.TestDataset.tpms-test`
LIMIT 50;
import io
import zipfile
from google.cloud import storage

storage_client = storage.Client()

def unzip_gcs_file(event, context):
    bucket_name = event['bucket']
    file_name = event['name']

    # جلوگیری infinite loop
    if not file_name.startswith("compressed/"):
        print(f"Skipping file outside compressed/: {file_name}")
        return

    if not file_name.endswith(".zip"):
        print(f"Skipping non-zip file: {file_name}")
        return

    print(f"Processing file: {file_name}")

    bucket = storage_client.bucket(bucket_name)
    blob = bucket.blob(file_name)

    # Stream zip file into memory (NO local disk)
    zip_bytes = blob.download_as_bytes()

    with zipfile.ZipFile(io.BytesIO(zip_bytes)) as z:
        for zip_info in z.infolist():
            if zip_info.is_dir():
                continue

            extracted_path = f"decompressed/{zip_info.filename}"
            extracted_blob = bucket.blob(extracted_path)

            print(f"Uploading: {extracted_path}")

            # Read file from zip and upload directly
            with z.open(zip_info.filename) as file_data:
                extracted_blob.upload_from_file(file_data)
